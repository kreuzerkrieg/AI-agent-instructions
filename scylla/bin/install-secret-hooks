#!/usr/bin/env bash
# install-secret-hooks — install gitleaks pre-commit + pre-push hooks into a git repo
#
# Usage:
#   install-secret-hooks [/path/to/repo]   # defaults to current directory
#
# Requires: gitleaks (sudo dnf install gitleaks  OR  brew install gitleaks)

set -euo pipefail

REPO="${1:-$(git rev-parse --show-toplevel 2>/dev/null || echo ".")}"
HOOKS_DIR="$REPO/.git/hooks"

if [[ ! -d "$HOOKS_DIR" ]]; then
    echo "ERROR: $REPO is not a git repository (no .git/hooks dir)" >&2
    exit 1
fi

if ! command -v gitleaks &>/dev/null; then
    echo "ERROR: gitleaks not found. Install it first:" >&2
    echo "  Fedora/RHEL:  sudo dnf install gitleaks" >&2
    echo "  macOS:        brew install gitleaks" >&2
    echo "  Other:        https://github.com/gitleaks/gitleaks#installing" >&2
    exit 1
fi

# Global gitleaks config (custom rules for Jenkins tokens, netrc patterns, etc.)
GITLEAKS_CONFIG="${HOME}/.gitleaks.toml"
GITLEAKS_CONFIG_ARG=""
if [[ -f "$GITLEAKS_CONFIG" ]]; then
    GITLEAKS_CONFIG_ARG="-c $GITLEAKS_CONFIG"
fi

# ── pre-commit hook ──────────────────────────────────────────────────────────
cat > "$HOOKS_DIR/pre-commit" << HOOKEOF
#!/usr/bin/env bash
# Secret scanner — runs on every commit (staged files only)
set -euo pipefail

if ! command -v gitleaks &>/dev/null; then
    echo "⚠️  gitleaks not found — secret scanning skipped. Install it!" >&2
    exit 0
fi

GITLEAKS_CONFIG_ARG=""
[[ -f "\${HOME}/.gitleaks.toml" ]] && GITLEAKS_CONFIG_ARG="-c \${HOME}/.gitleaks.toml"

echo "🔍 Scanning staged changes for secrets..."

# Dump staged diff to a temp file and scan it
STAGED_DIFF=\$(mktemp /tmp/gitleaks-staged.XXXXXX)
git diff --cached --unified=0 > "\$STAGED_DIFF"

if [[ ! -s "\$STAGED_DIFF" ]]; then
    rm -f "\$STAGED_DIFF"
    echo "✅ No staged changes to scan."
    exit 0
fi

# Use 'detect' on the diff pipe — catches additions in this commit
if ! gitleaks detect \$GITLEAKS_CONFIG_ARG --pipe --exit-code 1 < "\$STAGED_DIFF" 2>/tmp/gitleaks-pre-commit.log; then
    rm -f "\$STAGED_DIFF"
    echo ""
    echo "🚨🚨🚨 SECRET DETECTED — COMMIT ABORTED 🚨🚨🚨"
    echo ""
    cat /tmp/gitleaks-pre-commit.log
    echo ""
    echo "Fix: remove the secret, use a placeholder like <YOUR_TOKEN>, and retry."
    echo "If this is a false positive: git commit --no-verify  (use VERY sparingly!)"
    exit 1
fi

rm -f "\$STAGED_DIFF"
echo "✅ No secrets detected in staged changes."
HOOKEOF
chmod +x "$HOOKS_DIR/pre-commit"

# ── pre-push hook ────────────────────────────────────────────────────────────
cat > "$HOOKS_DIR/pre-push" << HOOKEOF
#!/usr/bin/env bash
# Secret scanner — last-chance check before pushing to remote
set -euo pipefail

if ! command -v gitleaks &>/dev/null; then
    echo "⚠️  gitleaks not found — secret scanning skipped. Install it!" >&2
    exit 0
fi

GITLEAKS_CONFIG_ARG=""
[[ -f "\${HOME}/.gitleaks.toml" ]] && GITLEAKS_CONFIG_ARG="-c \${HOME}/.gitleaks.toml"

# Read the list of refs being pushed from stdin
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
    # Skip deletes
    [[ "\$local_sha" == "0000000000000000000000000000000000000000" ]] && continue

    # Determine range: if remote_sha is all zeros, scan all commits on this branch
    if [[ "\$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
        LOG_OPTS="\$local_sha"
    else
        LOG_OPTS="\$remote_sha..\$local_sha"
    fi

    echo "🔍 Scanning unpushed commits (\$LOG_OPTS) for secrets..."

    if ! gitleaks detect \$GITLEAKS_CONFIG_ARG --source . --log-opts "\$LOG_OPTS" --exit-code 1 \
           2>/tmp/gitleaks-pre-push.log; then
        echo ""
        echo "🚨🚨🚨 SECRET DETECTED IN COMMITS — PUSH ABORTED 🚨🚨🚨"
        echo ""
        cat /tmp/gitleaks-pre-push.log
        echo ""
        echo "Fix:"
        echo "  1. git-filter-repo --replace-text <(echo 'SECRET==>PLACEHOLDER')"
        echo "  2. git push --force"
        echo "  3. Rotate the credential IMMEDIATELY."
        echo ""
        echo "If this is a false positive: git push --no-verify  (use VERY sparingly!)"
        exit 1
    fi
done

echo "✅ No secrets detected — push proceeding."
HOOKEOF
chmod +x "$HOOKS_DIR/pre-push"

echo ""
echo "✅ Secret-scanning hooks installed in $REPO"
echo "   • pre-commit: scans staged files on every commit"
echo "   • pre-push:   scans unpushed commits before push"
echo ""
echo "Powered by gitleaks $(gitleaks version 2>/dev/null || echo '(version unknown)')"


