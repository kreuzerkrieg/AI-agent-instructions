# Ignore everything by default — this directory is managed by IntelliJ/Copilot
# and arbitrary files may appear. Only explicitly whitelisted files are tracked.
*

# Whitelist repo infrastructure
!.gitignore
!.gitmodules
!LICENSE
!README.md

# Whitelist MCP configuration
!mcp.json

# Whitelist instruction files
!global-agents.instructions.md
!scylla/
!scylla/**
!personal/
!personal/**
!clion-code-nav/
!clion-code-nav/**

# Whitelist scratch templates (canonical sources seeded into the CLion scratches dir)
!scratch/
!scratch/**

!copilot-oom-prevention.md

# Whitelist the Copilot history export tool (source files only — never dumps/ or *.class).
!copilot-history-export/
!copilot-history-export/*.java
!copilot-history-export/*.py
!copilot-history-export/*.sh
!copilot-history-export/README.md

