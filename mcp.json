{
  "servers": {
    "io.github.github/github-mcp-server": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "requestInit": {
        "headers": {
          "Authorization": ""
        }
      },
      "x-metadata": {
        "registry": {
          "api": {
            "baseUrl": "https://api.mcp.github.com",
            "version": "v0.1"
          },
          "mcpServer": {
            "name": "io.github.github/github-mcp-server",
            "version": "0.34.0"
          }
        }
      }
    },
    "io.github.tavily-ai/tavily-mcp": {
      "type": "http",
      "url": "https://mcp.tavily.com/mcp/",
      "x-metadata": {
        "registry": {
          "api": {
            "baseUrl": "https://api.mcp.github.com",
            "version": "v0.1"
          },
          "mcpServer": {
            "name": "io.github.tavily-ai/tavily-mcp",
            "version": "0.2.15"
          }
        }
      }
    },
    "atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "context7": {
      "type": "http",
      "url": "https://mcp.context7.com/mcp"
    },
    "microsoft/markitdown": {
      "type": "stdio",
      "command": "uvx",
      "args": [
        "--refresh",
        "--with",
        "pydantic>=2.10,<2.14",
        "markitdown-mcp"
      ],
      "x-metadata": {
        "registry": {
          "api": {
            "baseUrl": "https://api.mcp.github.com",
            "version": "v0.1"
          },
          "mcpServer": {
            "name": "microsoft/markitdown",
            "version": "1.0.0"
          }
        }
      }
    },
    "scylla-backtrace": {
      "type": "http",
      "url": "https://backtrace.scylladb.com/mcp/",
      "enabled": true
    },
    "llama_index_docs": {
      "type": "http",
      "url": "https://developers.llamaindex.ai/mcp",
      "enabled": true
    },
    "prometheus-mcp": {
      "type": "stdio",
      "command": "/home/ernest.zaslavsky/Development/prometheus-mcp/venv/bin/python3",
      "args": [
        "/home/ernest.zaslavsky/Development/prometheus-mcp/local-mcp/prometheus_mcp_server.py",
        "--thanos-url",
        "https://thanos.app.int.scylla.cloud",
        "--metrics-meta-file",
        "/home/ernest.zaslavsky/Development/prometheus-mcp/local-mcp/enriched_metrics_catalog.yaml"
      ],
      "env": {
        "PYTHONUNBUFFERED": "1"
      },
      "enabled": true
    },
    "victorialogs": {
      "type": "http",
      "url": "https://victoria-logs-mcp.app.int.scylla.cloud/mcp",
      "enabled": true
    },
    "clion": {
      "url": "http://127.0.0.1:64362/sse",
      "type": "sse"
    }
  }
}